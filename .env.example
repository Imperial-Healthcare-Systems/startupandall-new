# ---------------------------------------------------------------------------
# Live Google rating for the home-page trust badges (OPTIONAL).
#
# When BOTH variables below are set, the Google Business Profile badge shows the
# live rating + review count fetched from the Google Places API at request time
# (cached ~24h). When they are absent, the badge falls back to the verified
# values in lib/reviews-data.ts. See docs/ratings.md for the full rationale.
#
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# A Google Cloud API key with the "Places API (New)" enabled + billing on.
# Server-only — never prefix with NEXT_PUBLIC.
GOOGLE_PLACES_API_KEY=

# Place ID for the business listing ("Sachin Gadekar Advisory LLP").
# Find it with: https://developers.google.com/maps/documentation/places/web-service/place-id
# (search the business name). It looks like: ChIJxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_PLACE_ID=
